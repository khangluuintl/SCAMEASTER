rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /products/{docId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    match /users/{userId} {
      // Admin check first so list queries short-circuit without needing per-doc userId match
      allow read, write: if request.auth != null &&
        (request.auth.token.admin == true || request.auth.uid == userId);
    }

    // Orders: anyone (including guests) can create; owner or admin can read; admin can update/delete
    match /orders/{orderId} {
      allow create: if true;
      // Admin check first — avoids resource.data evaluation failure on collection-wide list queries
      allow read: if request.auth != null &&
        (request.auth.token.admin == true || resource.data.userId == request.auth.uid);
      allow update: if request.auth != null && request.auth.token.admin == true;
      allow delete: if request.auth != null && request.auth.token.admin == true;
    }

    // Comments: anyone can read; authenticated users can create their own; admin can delete
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null &&
        (request.auth.token.admin == true || resource.data.userId == request.auth.uid);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
